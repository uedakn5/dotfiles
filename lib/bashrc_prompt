#!/bin/bash

C() {
  case $1 in
    black)    printf '\033[1;30m' ;;
    red)      printf '\033[1;31m' ;;
    green)    printf '\033[1;32m' ;;
    yellow)   printf '\033[1;33m' ;;
    blue)     printf '\033[1;34m' ;;
    magenta)  printf '\033[1;35m' ;;
    cyan)     printf '\033[1;36m' ;;
    white)    printf '\033[1;37m' ;;
    backcyan) printf '\033[1;46m' ;;
    *)        printf '\033[0m' ;;
  esac
}

ps1_sep() {
  printf '%s·%s' "$(C black)" "$(C reset)"
}

ps1_rails() {
  if [ -z "${RAILS_ENV-}" ]; then
    return
  fi
  printf ' %srails%s=%s%s%s' "$(C black)" "$(C reset)" "$(C white)" "$RAILS_ENV" "$(C reset)"
}

ps1_login() {
  printf '%s%s%s@' "$(C green)" "${USER}" "$(C reset)"
  printf '%s%s%s' "$(C cyan)" "$(hostname -s)" "$(C reset)"
}

ps1_date() {
  date +'%F %H:%M:%S'
}

ps1_exit_status() {
  local end_code=$1
  if [ "$end_code" -ne 0 ]; then
    printf ' %sstatus%s=%s%s%s' "$(C black)" "$(C reset)" "$(C red)" "$end_code" "$(C reset)"
  fi
}

ps1_git() {
  if ! git status --ignore-submodules &>/dev/null; then
    return
  fi
  printf ' '
  git-ps
}

ps1_session() {
  local session_name
  if is_ssh_session; then
    session_name="ssh"
  elif is_wsl; then
    session_name="wsl"
  else
    session_name="local"
  fi
  printf ' %ssession%s=%s%s%s' "$(C black)" "$(C reset)" "$(C yellow)" "$session_name" "$(C reset)"
}

ps1_python() {
  local env_name=""
  if [ -n "${VIRTUAL_ENV-}" ]; then
    env_name=$(basename "$VIRTUAL_ENV")
  elif [ -n "${CONDA_DEFAULT_ENV-}" ]; then
    env_name=$CONDA_DEFAULT_ENV
  elif [ -n "${POETRY_ACTIVE-}" ]; then
    env_name=$(basename "${VIRTUAL_ENV:-poetry}")
  fi

  if [ -n "$env_name" ]; then
    printf ' %spy%s=%s%s%s' "$(C black)" "$(C reset)" "$(C magenta)" "$env_name" "$(C reset)"
  fi
}

ps1_path() {
  local pwd_dir
  if [ "$(pwd -P)" != "$(pwd)" ]; then
    pwd_dir=" $(C white)($(C reset)$(C cyan)$(pwd | sed -e "s|^${HOME%/}|~|")$(C reset)$(C white))$(C reset)"
  else
    pwd_dir=""
  fi
  printf '%s%s%s%s' "$(C blue)" "$(pwd -P | sed -e "s|^${HOME%/}|~|")" "$(C reset)" "${pwd_dir}"
}

ps1_info() {
  local end_code=$?
  printf '%s%s%s' "$(ps1_login)" "$(ps1_exit_status "$end_code")" "$(ps1_git)$(ps1_session)$(ps1_python)$(ps1_rails)"
  printf '\n'
  printf '%s[%s %s %s %s %s]%s' "$(C black)" "$(C reset)" "$(ps1_date)" "$(ps1_sep)" "$(ps1_path)" "$(C black)" "$(C reset)"
  printf '\n'
}

if [ "$(id -u)" -ne 0 ]; then
  PS1='$(ps1_info)'
fi

# Keep the final prompt line as a literal string so readline counts width correctly.
if [ "$(id -u)" -eq 0 ]; then
  PS1="${PS1}\n\[\e[1;31m\]\# \[\e[m\]"
else
  PS1="${PS1}\n\[\e[0;37m\]\$ \[\e[m\]"
fi

export PS1
